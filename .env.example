# ---- Google Gemini (free tier) ----
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ---- Email (Gmail SMTP) ----
# 1. Enable 2-Step Verification on your Gmail account.
# 2. Visit https://myaccount.google.com/apppasswords and generate an "App Password" (16 chars).
# 3. Paste it below (no spaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM=your_gmail_address@gmail.com
EMAIL_TO=destination_email@example.com

# ---- Behavior ----
TIMEZONE=Africa/Algiers
MAX_LISTINGS_PER_SOURCE=50
TOP_OPPORTUNITIES_COUNT=10
DRY_RUN=false
